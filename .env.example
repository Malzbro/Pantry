# Get a key from https://aistudio.google.com
GOOGLE_API_KEY=

# Get a key from https://console.groq.com
GROQ_API_KEY=

# Postgres via Supabase transaction-mode pooler (for the app / FastAPI).
# Use the "Transaction" pooler string from Supabase → Settings → Database.
# Format: postgresql+psycopg://user:pass@host:6543/postgres
# Note: special characters in the password (like ?) must be URL-encoded (%3F).
# Do NOT include ?pgbouncer=true — psycopg v3 doesn't use it; prepare_threshold
# is set in code instead.
DATABASE_URL=

# Postgres direct/session-mode pooler (for Alembic migrations).
# Use the "Session" pooler string from Supabase → Settings → Database.
# Format: postgresql+psycopg://user:pass@host:5432/postgres
DIRECT_URL=
